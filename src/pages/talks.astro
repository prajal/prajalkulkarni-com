---
import Base from "@layouts/Base.astro";
import { talks, type Talk } from "@data/talks";

// Group talks by year, preserving order (newest first).
const groups: { year: string; items: Talk[] }[] = [];
for (const t of talks) {
  let g = groups.find((x) => x.year === t.year);
  if (!g) { g = { year: t.year, items: [] }; groups.push(g); }
  g.items.push(t);
}

const chipClass: Record<Talk['type'], string> = {
  talk:     'chip--talk',
  panel:    'chip--panel',
  podcast:  'chip--podcast',
  training: 'chip--training',
  review:   'chip--review',
};
const chipLabel: Record<Talk['type'], string> = {
  talk:     'Talk',
  panel:    'Panel',
  podcast:  'Podcast',
  training: 'Training',
  review:   'Review board',
};
---

<Base title="Talks — Prajal Kulkarni" description="Talks, trainings, panels, review boards, and conversations by Prajal Kulkarni across the security community." current="talks">
  <div class="wrap">
    <p class="eyebrow">Talks &amp; Conversations</p>
    <h1 class="display">A little time in the community.</h1>
    <p class="lede measure">I don't speak as often as I once did, but I still love the community that taught me most of what I know. A few talks, trainings, panels, and conversations over the years.</p>

    <div class="talks">
      <div class="talks-tabs" role="tablist" aria-label="Filter by type">
        <button class="talks-tab active" onclick="filterTalks('all',this)" role="tab" aria-selected="true">All</button>
        <button class="talks-tab" onclick="filterTalks('talk',this)" role="tab" aria-selected="false">Talks</button>
        <button class="talks-tab" onclick="filterTalks('panel',this)" role="tab" aria-selected="false">Panels</button>
        <button class="talks-tab" onclick="filterTalks('podcast',this)" role="tab" aria-selected="false">Podcasts</button>
        <button class="talks-tab" onclick="filterTalks('training',this)" role="tab" aria-selected="false">Training</button>
        <button class="talks-tab" onclick="filterTalks('review',this)" role="tab" aria-selected="false">Review</button>
      </div>
      {groups.map((g) => (
        <div class="year-group">
          <p class="year-group__year">{g.year}</p>
          <div class="year-group__list">
            {g.items.map((t) => (
              t.href ? (
                <a class="talk" data-type={t.type} href={t.href} target="_blank" rel="noopener">
                  <span class="talk__main">
                    <span class="talk__title">{t.title}</span>
                    <span class="talk__event">{t.event} <span class:list={["chip", chipClass[t.type]]}>{chipLabel[t.type]}</span></span>
                  </span>
                  <span class="talk__arrow">↗</span>
                </a>
              ) : (
                <div class="talk" data-type={t.type}>
                  <span class="talk__main">
                    <span class="talk__title">{t.title}</span>
                    <span class="talk__event">{t.event} <span class:list={["chip", chipClass[t.type]]}>{chipLabel[t.type]}</span></span>
                  </span>
                </div>
              )
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>

<script is:inline>
function filterTalks(type, el) {
  document.querySelectorAll('.talks-tab').forEach(t => {
    t.classList.remove('active');
    t.setAttribute('aria-selected','false');
  });
  el.classList.add('active');
  el.setAttribute('aria-selected','true');
  document.querySelectorAll('.talk').forEach(r => {
    (r as HTMLElement).style.display = (type === 'all' || r.getAttribute('data-type') === type) ? '' : 'none';
  });
  document.querySelectorAll('.year-group').forEach(g => {
    const hasVisible = [...g.querySelectorAll('.talk')].some(r => (r as HTMLElement).style.display !== 'none');
    (g as HTMLElement).style.display = hasVisible ? '' : 'none';
  });
}
</script>

