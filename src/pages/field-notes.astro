---
import Base from "@layouts/Base.astro";
import { fieldNotes, type FieldNote } from "@data/fieldnotes";
import { inlineBold } from "../lib/format";

const chipClass: Record<FieldNote['topic'], string> = {
  'supply-chain': 'chip--talk',
  ai:             'chip--panel',
  vuln:           'chip--review',
  privacy:        'chip--training',
  identity:       'chip--podcast',
  culture:        'chip--culture',
};
const chipLabel: Record<FieldNote['topic'], string> = {
  'supply-chain': 'Supply Chain',
  ai:             'AI Security',
  vuln:           'Vuln Mgmt',
  privacy:        'Privacy',
  identity:       'Identity',
  culture:        'Culture',
};
---

<Base title="Field Notes — Prajal Kulkarni" description="Short, opinionated takes on the security news that crosses my desk — by Prajal Kulkarni." current="notes">
  <div class="wrap">
    <p class="eyebrow">Field Notes</p>
    <h1 class="display">Short takes on security news.</h1>
    <p class="lede measure">Quick, opinionated notes on the security events that cross my desk — what actually matters, and what doesn't. The opinions are mine and mine only.</p>

    <div class="note-feed">
      {fieldNotes.map((n) => (
        <article class="note-card">
          <div class="note-card__top">
            <span class="note-card__date">{n.date}</span>
            <span class:list={["chip", chipClass[n.topic]]}>{chipLabel[n.topic]}</span>
          </div>
          <h2 class="note-card__title">{n.title}</h2>
          <p class="note-card__body" set:html={inlineBold(n.body)} />
        </article>
      ))}
    </div>
  </div>
</Base>
