---
import Base from "@layouts/Base.astro";
import { journey } from "@data/journey";
---

<Base title="Journey — Prajal Kulkarni" description="The path that took Prajal Kulkarni from vulnerability assessments to leading a security organization — and the people and lessons along the way." current="journey">
  <div class="wrap">
    <p class="eyebrow">Journey</p>
    <h1 class="display">The path so far.</h1>
    <p class="lede measure">A lot of people gave me chances I hadn't earned and patience I didn't deserve. This is roughly how I went from running vulnerability scans to leading a security organization — and the people and lessons that shaped each step.</p>

    <div class="timeline">
      {journey.map((e) => (
        <article class:list={["entry", { "entry--current": e.current }]}>
          <p class="entry__date">{e.dates}</p>
          <p class="entry__meta">
            <span class="co">{e.company}</span><span class="sep">·</span>{e.role}
          </p>
          <h2 class="entry__role">{e.title}</h2>
          <div class="entry__body"><p>{e.body}</p></div>
          {e.learned && (
            <div class="entry__learned"><span>{e.learned.label}</span>{e.learned.text}</div>
          )}
          {e.artifacts && (
            <>
              <button class="artifacts-toggle" onclick="var c=this.nextElementSibling;var open=c.classList.toggle('open');this.querySelector('.artifacts-toggle__icon').textContent=open?'−':'+';">
                <span class="artifacts-toggle__icon">+</span>
                <span class="artifacts-toggle__label">What we built</span>
              </button>
              <div class="artifacts-content">
                {e.artifacts.highlights && e.artifacts.highlights.length > 0 && (
                  <div class="artifacts-sub">
                    <p class="artifacts-sub__lbl">Highlights</p>
                    <ul class="artifacts-bullets">
                      {e.artifacts.highlights.map(h => <li>{h}</li>)}
                    </ul>
                  </div>
                )}
                {e.artifacts.tools && e.artifacts.tools.length > 0 && (
                  <div class="artifacts-sub">
                    <p class="artifacts-sub__lbl">Open source tools</p>
                    <div class="artifacts-pills">
                      {e.artifacts.tools.map(t => (
                        <a class="pill pill--tool" href={t.href} target="_blank" rel="noopener">{t.label} <span class="pill__arr">↗</span></a>
                      ))}
                    </div>
                  </div>
                )}
                {e.artifacts.writing && e.artifacts.writing.length > 0 && (
                  <div class="artifacts-sub">
                    <p class="artifacts-sub__lbl">{e.artifacts.writingLabel ?? "Writing"}</p>
                    <div class="artifacts-pills">
                      {e.artifacts.writing.map(w => (
                        <a class="pill" href={w.href} target="_blank" rel="noopener">{w.label} <span class="pill__arr">↗</span></a>
                      ))}
                    </div>
                  </div>
                )}
                {e.artifacts.cves && e.artifacts.cves.length > 0 && (
                  <div class="artifacts-sub">
                    <p class="artifacts-sub__lbl">CVEs — {e.artifacts.cves.length} advisories</p>
                    <div class="artifacts-pills">
                      {e.artifacts.cves.map(c => (
                        <a class="pill pill--cve" href={c.href} target="_blank" rel="noopener">{c.id}</a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </>
          )}
        </article>
      ))}
    </div>
  </div>
</Base>
