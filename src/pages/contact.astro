---
import Base from "@layouts/Base.astro";
import { site } from "@data/site";
---

<Base title="Contact — Prajal Kulkarni" description="Get in touch with Prajal Kulkarni about security leadership, speaking, or collaboration." current="contact">
  <div class="wrap">
    <p class="eyebrow">Contact</p>
    <h1 class="display">Let's talk.</h1>
    <p class="lede measure">{site.contact.blurb}</p>

    <div class="contact-links">
      {site.contact.links.map((l) => (
        <a
          class="contact-link"
          href={l.href}
          target={l.href.startsWith("mailto:") ? undefined : "_blank"}
          rel={l.href.startsWith("mailto:") ? undefined : "noopener"}
        >
          {l.label} <span class="arr">↗</span>
        </a>
      ))}
    </div>
  </div>
</Base>
